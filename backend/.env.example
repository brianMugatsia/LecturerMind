# --- App ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=postgresql+asyncpg://lecturermind:lecturermind@localhost:5432/lecturermind
DATABASE_URL_SYNC=postgresql+psycopg2://lecturermind:lecturermind@localhost:5432/lecturermind

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Speech-to-Text (Deepgram) ---
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# --- Storage (S3 / R2) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=lecturermind-audio
S3_REGION=auto

# --- Notes/Quiz generation tuning ---
NOTES_DEBOUNCE_SECONDS=45
QUIZ_QUESTION_COUNT=10
